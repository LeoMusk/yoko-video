# Required for M2 scoring and M3 script generation.
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# News window. The public default is 3 days.
NEWS_SINCE_DAYS=3

# Cost controls for daily scoring.
MAX_UNSCORED=120
BRIEF_TOP_N=40

# Script generation defaults.
SCRIPT_TOP=2

# Optional: use a custom creator profile instead of config/profile.json.
# YOKO_PROFILE_PATH=config/profile.json
